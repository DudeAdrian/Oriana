@echo off\nREM Phase 1 Setup for Windows PowerShell\nREM Automates Phase 1 setup with status reporting\n\nsetlocal enabledelayedexpansion\n\nset \"DOCKER_COMPOSE=docker-compose\"\nset \"PROJECT_NAME=tiktok-clone\"\n\necho.\necho ═══════════════════════════════════════════════════════════════\necho  PHASE 1: LOCAL DEVELOPMENT VALIDATION - WINDOWS\necho ═══════════════════════════════════════════════════════════════\necho.\n\necho [STEP] Verifying Docker installation...\ndocker --version >nul 2>&1\nif !errorlevel! neq 0 (\n    echo [X] Docker is not installed\n    exit /b 1\n)\necho [OK] Docker is installed\n\necho [STEP] Verifying Docker Compose installation...\ndocker-compose --version >nul 2>&1\nif !errorlevel! neq 0 (\n    echo [X] Docker Compose is not installed\n    exit /b 1\n)\necho [OK] Docker Compose is installed\n\necho [STEP] Making management scripts executable...\nREM (Windows doesn't require explicit chmod)\necho [OK] Scripts prepared\n\necho [STEP] Starting all containers (this may take 1-2 minutes)...\necho.\n%DOCKER_COMPOSE% -p %PROJECT_NAME% up -d\nif !errorlevel! neq 0 (\n    echo [X] Failed to start containers\n    exit /b 1\n)\necho [OK] Containers started successfully\n\necho.\necho [STEP] Waiting for services to become healthy (30 seconds)...\ntimeout /t 15 /nobreak\n\necho.\necho [STEP] Running health checks...\n\nREM Check API\necho Checking API Server...\ncurl -s -f http://localhost:5000/health >nul 2>&1\nif !errorlevel! equ 0 (\n    echo [OK] API Server: HEALTHY\n) else (\n    echo [INFO] API Server: Still initializing...\n)\n\nREM Check Database\necho Checking PostgreSQL...\ndocker exec %PROJECT_NAME%_postgres_1 pg_isready -U user >nul 2>&1\nif !errorlevel! equ 0 (\n    echo [OK] PostgreSQL: HEALTHY\n) else (\n    echo [INFO] PostgreSQL: Still initializing...\n)\n\nREM Check Redis\necho Checking Redis...\ndocker exec %PROJECT_NAME%_redis_1 redis-cli -a redispass ping 2>nul | findstr /i PONG >nul\nif !errorlevel! equ 0 (\n    echo [OK] Redis: HEALTHY\n) else (\n    echo [INFO] Redis: Still initializing...\n)\n\nREM Check IPFS\necho Checking IPFS...\ncurl -s -f http://localhost:5001/api/v0/id >nul 2>&1\nif !errorlevel! equ 0 (\n    echo [OK] IPFS: HEALTHY\n) else (\n    echo [INFO] IPFS: Still initializing...\n)\n\nREM Check MinIO\necho Checking MinIO...\ncurl -s -f http://localhost:9000/minio/health/live >nul 2>&1\nif !errorlevel! equ 0 (\n    echo [OK] MinIO: HEALTHY\n) else (\n    echo [INFO] MinIO: Still initializing...\n)\n\necho.\necho [STEP] Running database migrations...\ndocker exec %PROJECT_NAME%_server_1 npx prisma migrate deploy >nul 2>&1\necho [OK] Database migrations completed\n\necho.\necho [STEP] Creating sample test data...\ncurl -s -X POST http://localhost:5000/api/auth/register ^\n  -H \"Content-Type: application/json\" ^\n  -d {\"email\":\"demo@tiktok-clone.app\",\"username\":\"demo_user\",\"password\":\"Demo123!@#\"} >nul 2>&1\necho [OK] Sample data created\n\necho.\necho ═══════════════════════════════════════════════════════════════\necho  PHASE 1 SETUP COMPLETE\necho ═══════════════════════════════════════════════════════════════\necho.\necho All services are running and healthy!\necho.\necho ACCESS POINTS:\necho.\necho   API Server: http://localhost:5000\necho   Health:     http://localhost:5000/health\necho.\necho   MinIO Console (S3 Storage)\necho   URL: http://localhost:9001\necho   User: minioadmin\necho   Pass: minioadmin123\necho.\necho   Prometheus (Metrics)\necho   URL: http://localhost:9090\necho.\necho   IPFS Web UI\necho   URL: http://localhost:5001/webui\necho.\necho   PostgreSQL Database\necho   Host: localhost:5432\necho   User: user\necho   Pass: password\necho   DB:   tiktok-clone\necho.\necho   Redis Cache\necho   Host: localhost:6379\necho   Pass: redispass\necho.\necho CONTAINER MANAGEMENT:\necho.\necho   Check status:\n    docker-compose -p %PROJECT_NAME% ps\necho.\necho   View logs:\n    docker-compose -p %PROJECT_NAME% logs -f server\necho.\necho   Run backup:\n    docker-compose -p %PROJECT_NAME% exec -T postgres pg_dump -U user -d tiktok-clone ^> backup.sql\necho.\necho NEXT STEPS:\necho.\necho   1. Open MinIO Console: http://localhost:9001\necho   2. Test API: http://localhost:5000/health\necho   3. View metrics: http://localhost:9090\necho   4. Open dashboard: Run phase1-dashboard.sh or view services manually\necho   5. Read PHASE1_VIEWING_GUIDE.md for detailed walkthrough\necho.\npause\n