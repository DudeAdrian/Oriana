{
    "name": "oriana-workspace",
    "version": "1.0.0",
    "description": "Oriana Ecosystem - High-Density Secure Communication Architecture",
    "private": true,
    "workspaces": [
        "apps/mobile",
        "apps/server"
    ],
    "scripts": {
        "dev:server": "cd apps/server && npm run dev",
        "dev:mobile": "cd apps/mobile && npm start",
        "build:server": "cd apps/server && npm run build",
        "build:mobile": "cd apps/mobile && npm run build",
        "install:all": "npm install && npm install -w apps/server && npm install -w apps/mobile"
    },
    "keywords": [
        "oriana",
        "secure",
        "messaging",
        "privacy"
    ],
    "author": "",
    "license": "MIT",
    "overrides": {
        "@xmldom/xmldom": ">=0.8.12",
        "fast-xml-parser": ">=5.7.0",
        "postcss": ">=8.5.10",
        "semver": ">=7.5.4",
        "send": ">=0.19.0",
        "serialize-javascript": ">=7.0.5",
        "tar": ">=7.5.11",
        "webpack-dev-server": ">=5.2.1",
        "multer": ">=1.4.5-lts.7"
    },
    "dependencies": {
        "metro-config": "^0.84.4"
    }
}
