# TikTok Clone - Development Environment Configuration\n# Copy to .env and customize for your environment\n\n# ==================== APPLICATION ====================\nNODE_ENV=development\nPORT=5000\nJWT_SECRET=your-jwt-secret-key-change-in-production-12345\nJWT_EXPIRY=7d\nLOG_LEVEL=debug\n\n# ==================== DATABASE ====================\n# PostgreSQL Configuration\nDB_HOST=postgres\nDB_PORT=5432\nDB_NAME=tiktok-clone\nDB_USER=user\nDB_PASSWORD=password\nDATABASE_URL=postgresql://user:password@postgres:5432/tiktok-clone\n\n# Database backup settings\nDB_BACKUP_ENABLED=true\nDB_BACKUP_SCHEDULE=\"0 2 * * *\"  # 2 AM daily\n\n# ==================== REDIS CACHE ====================\nREDIS_HOST=redis\nREDIS_PORT=6379\nREDIS_PASSWORD=redispass\nREDIS_URL=redis://:redispass@redis:6379\nREDIS_DB=0\nREDIS_TTL=3600  # 1 hour\n\n# ==================== IPFS ====================\nIPFS_NODE=ipfs\nIPFS_API_URL=http://ipfs:5001\nIPFS_GATEWAY=http://ipfs:8080\nIPFS_ENABLE_PUBSUB=true\nIPFS_API_PORT=5001\nIPFS_GATEWAY_PORT=8080\n\n# Pinata (IPFS Pinning Service)\nPINATA_API_KEY=\nPINATA_SECRET_KEY=\nPINATA_ENABLE=false  # Set to true if using Pinata\n\n# ==================== STORAGE (MinIO / S3) ====================\n# Local MinIO Configuration (Development)\nMINIO_ROOT_USER=minioadmin\nMINIO_ROOT_PASSWORD=minioadmin123\nMINIO_API_PORT=9000\nMINIO_CONSOLE_PORT=9001\n\n# S3 Configuration\nS3_ENDPOINT=http://minio:9000\nS3_ACCESS_KEY=minioadmin\nS3_SECRET_KEY=minioadmin123\nS3_BUCKET=tiktok-content\nS3_REGION=us-east-1\nS3_FORCE_PATH_STYLE=true\n\n# ==================== AWS (Production) ====================\n# Default to local MinIO in development\nAWS_REGION=ap-southeast-2\nAWS_ACCESS_KEY_ID=\nAWS_SECRET_ACCESS_KEY=\nAWS_S3_BUCKET=tiktok-clone-content-au\nAWS_ENDPOINT=  # Leave empty for real AWS, use http://minio:9000 for local\n\n# ==================== STORAGE SETTINGS ====================\n# Hybrid Storage Configuration\nSTORAGE_TYPE=hybrid  # Options: s3, ipfs, hybrid\nSTORAGE_S3_ENABLED=true\nSTORAGE_IPFS_ENABLED=true\nSTORAGE_S3_PRIMARY=true\n\n# File size limits\nMAX_VIDEO_SIZE=104857600  # 100MB\nMAX_IMAGE_SIZE=10485760   # 10MB\nMAX_FILE_SIZE=104857600   # 100MB\n\n# Media settings\nVIDEO_COMPRESSION_ENABLED=true\nVIDEO_THUMBNAIL_ENABLED=true\nIMAGE_OPTIMIZATION_ENABLED=true\n\n# ==================== CORS & SECURITY ====================\nCORS_ORIGIN=*\nCORS_CREDENTIALS=true\nTRUST_PROXY=true\n\n# Rate limiting\nRATE_LIMIT_ENABLED=true\nRATE_LIMIT_WINDOW=15m\nRATE_LIMIT_MAX_REQUESTS=100\nRATE_LIMIT_AUTH_MAX=10\nRATE_LIMIT_AUTH_WINDOW=5m\n\n# ==================== NGINX CONFIGURATION ====================\nNGINX_ENABLED=true\nNGINX_WORKER_PROCESSES=auto\nNGINX_WORKER_CONNECTIONS=1024\nNGINX_CACHE_ENABLED=true\nNGINX_GZIP_ENABLED=true\n\n# ==================== MONITORING & LOGGING ====================\nPROMETHEUS_ENABLED=true\nPROMETHEUS_PORT=9090\nPROMETHEUS_SCRAPE_INTERVAL=15s\n\nELASTICSEARCH_ENABLED=true\nELASTICSEARCH_HOST=elasticsearch\nELASTICSEARCH_PORT=9200\n\n# Application metrics\nMETRICS_ENABLED=true\nMETRICS_COLLECTION_INTERVAL=10s\n\n# ==================== BACKUP & RECOVERY ====================\nBACKUP_ENABLED=true\nBACKUP_SCHEDULE=\"0 2 * * *\"  # 2 AM daily\nBACKUP_RETENTION_DAYS=30\nBACKUP_COMPRESSION=true\n\n# Multi-region configuration\nMULTI_REGION_ENABLED=false\nPRIMARY_REGION=ap-southeast-2\nSECONDARY_REGIONS=ap-southeast-1,ap-northeast-1\n\n# ==================== FEATURES ====================\nFEATURE_REAL_TIME=true\nFEATURE_NOTIFICATIONS=true\nFEATURE_MESSAGING=true\nFEATURE_LIVE_STREAMING=false  # Future feature\nFEATURE_RECOMMENDATIONS=false  # Future feature\n\n# ==================== DOCKER ====================\nCONTAINER_NETWORK=tiktok-net\nCONTAINER_SUBNET=172.25.0.0/16\nDOCKER_RESTART_POLICY=unless-stopped\nDOCKER_LOG_DRIVER=json-file\nDOCKER_LOG_MAX_SIZE=10m\nDOCKER_LOG_MAX_FILE=3\n\n# ==================== HEALTH CHECKS ====================\nHEALTH_CHECK_INTERVAL=10s\nHEALTH_CHECK_TIMEOUT=5s\nHEALTH_CHECK_RETRIES=5\nHEALTH_CHECK_START_PERIOD=15s\n