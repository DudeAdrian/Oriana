@echo off\nREM Container Management Script for TikTok Clone (Windows PowerShell)\nREM This script provides comprehensive Docker Compose operations\n\nsetlocal enabledelayedexpansion\n\nset \"DOCKER_COMPOSE=docker-compose\"\nset \"PROJECT_NAME=tiktok-clone\"\nset \"ENV_FILE=.env\"\n\nif \"%1\"==\" \" (\n    call :show_help\n    exit /b 0\n) else if \"%1\"==\"\" (\n    call :show_help\n    exit /b 0\n)\n\nif \"%1\"==\"up\" (\n    call :up\n) else if \"%1\"==\"down\" (\n    call :down\n) else if \"%1\"==\"ps\" (\n    call :ps_containers\n) else if \"%1\"==\"logs\" (\n    call :show_logs %2\n) else if \"%1\"==\"build\" (\n    call :build_images\n) else if \"%1\"==\"shell\" (\n    call :shell_access %2\n) else if \"%1\"==\"status\" (\n    call :status\n) else if \"%1\"==\"restart\" (\n    call :restart_containers %2\n) else if \"%1\"==\"clean\" (\n    call :clean\n) else if \"%1\"==\"backup\" (\n    call :backup_database\n) else if \"%1\"==\"health-check\" (\n    call :health_check\n) else (\n    call :show_help\n)\nexit /b 0\n\n:show_help\necho TikTok Clone Container Management\necho.\necho Usage: manage.cmd [COMMAND] [OPTIONS]\necho.\necho Commands:\necho   up              Start all containers\necho   down            Stop all containers\necho   ps              Show running containers\necho   logs [service]  Show container logs\necho   build           Build Docker images\necho   shell [service] Open shell in container\necho   status          Show container status\necho   restart         Restart containers\necho   clean           Remove all containers and volumes\necho   backup          Backup database\necho   health-check    Run health checks\necho.\necho Examples:\necho   manage.cmd up          - Start all services\necho   manage.cmd status      - Check service health\necho   manage.cmd shell postgres - Connect to PostgreSQL\nexit /b 0\n\n:up\necho Starting TikTok Clone containers...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% up -d\necho Containers started successfully!\ntimeout /t 3 /nobreak\ncall :status\nexit /b 0\n\n:down\necho Stopping TikTok Clone containers...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% down\necho Containers stopped\nexit /b 0\n\n:ps_containers\n%DOCKER_COMPOSE% -p %PROJECT_NAME% ps\nexit /b 0\n\n:show_logs\nif \"%1\"==\" \" (\n    set \"service_name=server\"\n) else (\n    set \"service_name=%1\"\n)\necho Showing logs for %service_name%...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% logs -f %service_name%\nexit /b 0\n\n:build_images\necho Building Docker images...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% build\necho Images built successfully!\nexit /b 0\n\n:shell_access\nif \"%1\"==\" \" (\n    echo Error: Please specify service name\n    echo Available services: postgres, redis, ipfs, minio, server, nginx\n    exit /b 1\n)\necho Opening shell in %1...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% exec %1 /bin/sh\nexit /b 0\n\n:status\necho.\necho === TikTok Clone Container Status ===\necho.\n%DOCKER_COMPOSE% -p %PROJECT_NAME% ps\necho.\nexit /b 0\n\n:restart_containers\necho Restarting containers...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% restart %1\necho Restart complete\nexit /b 0\n\n:clean\necho WARNING: This will remove all containers and volumes!\nset /p confirm=\"Continue? (yes/no): \"\nif /i \"%confirm%\"==\"yes\" (\n    echo Cleaning up...\n    %DOCKER_COMPOSE% -p %PROJECT_NAME% down -v\n    echo Cleanup complete\n) else (\n    echo Cancelled\n)\nexit /b 0\n\n:backup_database\nfor /f \"tokens=2-4 delims=/ \" %%a in ('date /t') do (set \"mydate=%%c%%a%%b\")\nfor /f \"tokens=1-2 delims=/\" %%a in ('time /t') do (set \"mytime=%%a%%b\")\nset \"timestamp=%mydate%_%mytime%\"\nset \"backup_file=backups\\tiktok-db-%timestamp%.sql\"\n\nif not exist backups mkdir backups\n\necho Backing up database to %backup_file%...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% exec -T postgres pg_dump -U user -d tiktok-clone > \"%backup_file%\"\necho Backup complete: %backup_file%\nexit /b 0\n\n:health_check\necho.\necho === Running Health Checks ===\necho.\n\necho Checking API Server...\ncurl -f http://localhost:5000/health >nul 2>&1\nif !ERRORLEVEL! equ 0 (\n    echo API Server: OK\n) else (\n    echo API Server: FAILED\n)\n\necho Checking Docker containers...\n%DOCKER_COMPOSE% -p %PROJECT_NAME% ps\necho.\nexit /b 0\n